# Normaliza fim de linha automaticamente (evita ruído CRLF/LF entre máquinas).
* text=auto

# Fontes tratados como texto.
*.cs      text
*.csproj  text
*.sln     text eol=crlf
*.md      text
*.resx    text
*.json    text
*.yml     text

# Binários (por segurança, se algum entrar no repo).
*.png binary
*.ico binary
